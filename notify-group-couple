#!/bin/zsh
# notify-group-couple — send a notification to the couple group across all
# channels configured for the "group-couple" route
# (currently Telegram 小寶murmur + LINE 海老群).
#
# Naming convention: future groups get their own shim, notify-group-<name>,
# backed by a matching route in routes.json.
#
# Usage:
#   notify-group-couple "message text"
#   echo "message text" | notify-group-couple
#   notify-group-couple --dry-run "preview only"
set -euo pipefail
here="${0:A:h}"
exec /usr/bin/env python3 "$here/notify_core.py" --route group-couple "$@"
